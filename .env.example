# =============================================
# BETTING BOT SETTINGS
# =============================================

# ── DATABASE ──────────────────────────────────
# Railway MySQL ki details yahan aayegi
DB_HOST=localhost
DB_USER=root
DB_PASS=your_database_password
DB_NAME=betting_bot
DB_PORT=3306

# ── SERVER ────────────────────────────────────
PORT=3000

# ── ADMIN ─────────────────────────────────────
# Aapka WhatsApp number (country code ke saath)
# Example: 919876543210 (91 = India code)
ADMIN_PHONE=91XXXXXXXXXX

# Admin panel login
JWT_SECRET=koi_bhi_random_string_likho_yahan

# ── UPI SETTINGS ──────────────────────────────
# Jis UPI par users payment karenge
ADMIN_UPI=yourname@upi
ADMIN_NAME=Betting Admin

# ── BET LIMITS ────────────────────────────────
MIN_BET=10
MIN_DEPOSIT=100
MAX_DEPOSIT=50000
MIN_WITHDRAW=200
MAX_WITHDRAW=25000

# ── SMS GATEWAY ───────────────────────────────
# Android app se SMS aane ka secret key
# Koi bhi random password rakho
SMS_SECRET=sms_secret_password_123
